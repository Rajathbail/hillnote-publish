{
  "name": "@hillnote/publish",
  "version": "1.2.0",
  "description": "Transform your Hillnote workspace into a beautiful documentation website with Next.js",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hillnote-publish": "./bin/cli.js"
  },
  "files": [
    "bin",
    "templates",
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "node scripts/build.js"
  },
  "keywords": [
    "hillnote",
    "documentation",
    "nextjs",
    "static-site-generator",
    "markdown",
    "wiki"
  ],
  "author": "Rajath Bail",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rajathbail/hillnote-publish"
  },
  "homepage": "https://hillnote.com",
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.542.0",
    "marked": "^16.2.1",
    "marked-gfm-heading-id": "^4.1.2",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.3.1",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "fs-extra": "^11.2.0"
  }
}